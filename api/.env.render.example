# ==============================================
# HOPPER API - CONFIGURAÇÃO RENDER.COM
# ==============================================
# 
# ⚠️ ATENÇÃO: Configure estas variáveis no Render Dashboard
# Não commite este arquivo se contiver valores reais!
#

# PowerBI / Azure AD Configuration
TENANT_ID = "SEU-TENANT-ID"
CLIENT_ID = "SEU-CLIENT-ID"
CLIENT_SECRET = "SEU-CLIENT-SECRET"

# Database Configuration (SQLite)
DB_PATH=hopper.db

# JWT Configuration
# ⚠️ PRODUÇÃO: Gere uma chave segura com: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-please

# ==============================================
# 🚨 CONFIGURAÇÃO CRÍTICA PARA CORS
# ==============================================
# Esta variável resolve o erro 400 Bad Request no OPTIONS
# Configure com a URL do seu frontend (Vercel, Netlify, etc)
#
# Seu frontend Vercel: https://hopper-opal.vercel.app
# 
# Para múltiplos domínios, use vírgula:
# ALLOWED_ORIGINS=https://hopper-opal.vercel.app,https://outro-dominio.com
#
ALLOWED_ORIGINS=https://hopper-opal.vercel.app

# Logging Configuration
LOG_LEVEL = "INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE = "logs/api.log"  # Caminho para o arquivo de log (opcional)
